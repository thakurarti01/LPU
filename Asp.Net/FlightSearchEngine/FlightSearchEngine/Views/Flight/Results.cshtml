@using FlightSearchEngine.Models
@model IEnumerable<dynamic>

<h2>Search Results</h2>

@if (Model == null || !Model.Any())
{
    <p>No results found.</p>
}
else if (Model.Any() && Model.First() is FlightResult)
{
    <table border="1" cellpadding="5">
        <thead>
            <tr>
                <th>FlightId</th>
                <th>FlightName</th>
                <th>FlightType</th>
                <th>Source</th>
                <th>Destination</th>
                <th>TotalCost</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var flight in (IEnumerable<FlightSearchEngine.Models.FlightResult>)Model)
            {
                <tr>
                    <td>@flight.FlightId</td>
                    <td>@flight.FlightName</td>
                    <td>@flight.FlightType</td>
                    <td>@flight.FlightSource</td>
                    <td>@flight.FlightDestination</td>
                    <td>@flight.TotalCost.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
}
else if (Model.Any() && Model.First() is FlightHotelResult)
{
    <table border="1" cellpadding="5">
        <thead>
            <tr>
                <th>FlightId</th>
                <th>FlightName</th>
                <th>Source</th>
                <th>Destination</th>
                <th>HotelName</th>
                <th>TotalCost</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in (IEnumerable<FlightSearchEngine.Models.FlightHotelResult>)Model)
            {
                <tr>
                    <td>@item.FlightId</td>
                    <td>@item.FlightName</td>
                    <td>@item.FlightSource</td>
                    <td>@item.FlightDestination</td>
                    <td>@item.HotelName</td>
                    <td>@item.TotalCost.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
}

<div style="margin-top:10px;">
    <a asp-action="Index">Back to Search</a>
</div>